# Copy this file to .env and replace the placeholder with your actual key.
# .env is listed in .gitignore — never commit your real key.
#
# Get a free Groq API key (no credit card required) at:
# https://console.groq.com

GROQ_API_KEY=your_key_here

# Reddit API (free) — create a "script" app at https://www.reddit.com/prefs/apps
# You only need the client ID (under the app name) and the secret.
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=seattle-rag-research/0.1 by your_username
